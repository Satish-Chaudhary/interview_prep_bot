# ── Provider Selection ──
# Which AI provider to use for all core tasks.
# Currently using "groq" for fast, free cloud inference.
LLM_PROVIDER=groq
CORE_PROVIDER=groq

# ── Groq API (FREE cloud inference — recommended for deployment) ──
# Get a FREE key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ── Generation settings ──
# Core tasks: low temperature for deterministic, well-formed JSON
CORE_TEMPERATURE=0.3
CORE_MAX_TOKENS=1200

# Sidebar assistant chat: slightly more creative
ASSISTANT_TEMPERATURE=0.5
ASSISTANT_MAX_TOKENS=600

# ── Legacy / session settings ──
QUESTION_COUNT=10
TEMPERATURE_QUESTIONS=0.3
TEMPERATURE_EVALUATION=0.2
TIMEOUT=120
